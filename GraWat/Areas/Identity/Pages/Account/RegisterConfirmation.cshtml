@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "GraWat Dünyasına Hoş Geldiniz!";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="text-success mb-4">✨ @ViewData["Title"]</h1>
            <p class="lead" style="font-size: 1.2rem; font-weight: 500;">
                Üyeliğiniz başarıyla oluşturuldu. Güzellik ve bakım serüveninizde yanınızda olmaktan büyük mutluluk duyuyoruz!
            </p>

            @if (Model.DisplayConfirmAccountLink)
            {
                <div class="alert alert-secondary mt-4" role="alert" style="border-radius: 10px;">
                    <p class="mb-3">
                        <small><em>(Sistemimiz şu an geliştirme aşamasında olduğu için aşağıdaki butonu kullanarak onaylama işlemini tamamlayabilirsiniz.)</em></small>
                    </p>
                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-dark btn-lg px-5" style="border-radius: 30px;">
                        Hesabımı Onayla ve Giriş Yap
                    </a>
                </div>
            }
            else
            {
                <div class="mt-5">
                    <p>Lütfen e-posta adresinize gönderilen onay bağlantısını kontrol edin.</p>
                </div>
            }
        </div>
    </div>
</div>