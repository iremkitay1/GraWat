@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            <a class="nav-link text-white fw-bold" asp-controller="Profil" asp-action="Favorilerim">
                ❤️ Favorilerim
            </a>
        </li>
        <li class="nav-item me-3">
            <span class="text-warning fw-bold">👤 @User.Identity?.Name</span>
        </li>
        <li class="nav-item">
            <form class="form-inline m-0 p-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-pill px-3">
                    Çıkış
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="nav-link text-dark fw-bold" href="/Identity/Account/Register">Kayıt Ol</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-dark text-warning fw-bold rounded-pill px-4" href="/Identity/Account/Login">Giriş Yap</a>
        </li>
    }
</ul>