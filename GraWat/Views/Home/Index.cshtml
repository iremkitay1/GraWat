@model IEnumerable<GraWat.Models.Urun>

@{
    ViewData["Title"] = "GraWat Vitrin";
}

<div class="container mt-5 mb-5">
    @* Premium Hero Section *@
    <div class="hero-section text-center mb-5 d-flex flex-column justify-content-center align-items-center position-relative overflow-hidden" 
         style="background-image: url('/img/hero_background.png'); background-size: cover; background-position: center; border-radius: 24px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35); min-height: 380px; padding: 5rem 2rem;">
        
        @* Dark Overlay for Readability *@
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(59, 15, 66, 0.65) 0%, rgba(20, 5, 25, 0.8) 100%); z-index: 1;"></div>
        
        @* Ambient Light Rings *@
        <div class="position-absolute" style="width: 250px; height: 250px; background: rgba(255, 204, 0, 0.15); border-radius: 50%; filter: blur(60px); top: -80px; left: -40px; pointer-events: none; z-index: 1;"></div>
        <div class="position-absolute" style="width: 300px; height: 300px; background: rgba(255, 255, 255, 0.1); border-radius: 50%; filter: blur(70px); bottom: -100px; right: -60px; pointer-events: none; z-index: 1;"></div>

        <div class="position-relative" style="z-index: 2; max-width: 800px;">
            <span class="badge bg-warning text-dark fw-bold mb-3 px-3 py-2 text-uppercase" style="letter-spacing: 2px; font-size: 0.8rem; border-radius: 8px; box-shadow: 0 4px 10px rgba(255, 204, 0, 0.35);">
                ✨ Kozmetik & Güzellik
            </span>
            <h1 class="display-2 fw-bold text-white mb-3" style="text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6); font-weight: 800; letter-spacing: -1px;">
                GraWat Dünyasına Hoş Geldiniz
            </h1>
            <p class="lead text-light opacity-90 mx-auto mb-0" style="line-height: 1.8; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5); font-weight: 400; font-size: 1.25rem; max-width: 680px;">
                Güzelliğinize zarafet ve ışıltı katacak, en özel formüllerle hazırlanmış seçkin ve kaliteli kozmetik koleksiyonunu keşfedin.
            </p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var urun in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 bg-white position-relative" style="border-radius: 20px; transition: transform 0.3s ease, box-shadow 0.3s ease; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05) !important;" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 6px rgba(0,0,0,0.05)';" >
                    
                    @* Resim Alanı *@
                    <div class="position-relative w-100" style="padding-top: 100%; background: linear-gradient(135deg, #fcefe9 0%, #f3dcd4 100%);">
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center p-3">
                            @if (!string.IsNullOrEmpty(urun.ResimYolu))
                            {
                                <img src="/img/@urun.ResimYolu" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="@urun.Ad" />
                            }
                            else
                            {
                                <span style="font-size: 4rem;">💄</span>
                            }
                        </div>
                    </div>

                    @* İçerik Alanı *@
                    <div class="card-body d-flex flex-column justify-content-between p-3">
                        <div class="text-start">
                            <span class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">@urun.Kategori</span>
                            <h6 class="fw-bold text-dark text-truncate mt-1 mb-1" title="@urun.Ad" style="font-size: 1rem;">
                                @urun.Ad
                            </h6>
                            
                            @* Yıldızlı Değerlendirme *@
                            <div class="d-flex align-items-center mb-3">
                                <div class="text-warning me-2" style="font-size: 0.85rem;">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="text-muted" style="font-size: 0.8rem; font-weight: 500;">(5.0)</span>
                            </div>
                        </div>

                        @* Fiyat ve Aksiyon Butonu *@
                        <div class="d-flex align-items-center justify-content-between pt-2 border-top border-light">
                            <div class="text-start">
                                <span class="text-muted d-block" style="font-size: 0.75rem;">Fiyat</span>
                                <span class="fs-5 fw-bold text-dark">@urun.Fiyat.ToString("C")</span>
                            </div>
                            
                            @if (urun.StokAdedi > 0)
                            {
                                <button type="button" class="btn sepete-ekle-btn d-flex align-items-center justify-content-center" data-id="@urun.Id" 
                                        style="background-color: #3b0f42; color: white; width: 42px; height: 42px; border-radius: 12px; border: none; transition: all 0.2s ease;"
                                        onmouseover="this.style.backgroundColor='#5c1866'; this.style.transform='scale(1.05)';"
                                        onmouseout="this.style.backgroundColor='#3b0f42'; this.style.transform='scale(1)';">
                                    <i class="bi bi-plus-lg fs-4"></i>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn d-flex align-items-center justify-content-center" disabled 
                                        style="background-color: #e9ecef; color: #adb5bd; width: 42px; height: 42px; border-radius: 12px; border: none;">
                                    <i class="bi bi-x-lg fs-5"></i>
                                </button>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>