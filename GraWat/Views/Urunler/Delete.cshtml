@model GraWat.Models.Urun

@{
    ViewData["Title"] = "Ürün Sil";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h3 class="mb-0 fw-bold">⚠️ Ürünü Sil</h3>
                </div>

                <div class="card-body bg-light text-center">
                    <h5 class="text-dark mb-4">Bu ürünü veritabanından kalıcı olarak silmek istediğinize emin misiniz?</h5>

                    <ul class="list-group list-group-flush mb-4 text-start">
                        <li class="list-group-item"><strong>Ürün Adı:</strong> @Model.Ad</li>
                        <li class="list-group-item"><strong>Kategori:</strong> @Model.Kategori</li>
                        <li class="list-group-item text-success"><strong>Fiyat:</strong> @Model.Fiyat ₺</li>
                        <li class="list-group-item"><strong>Stok:</strong> @Model.StokAdedi</li>
                    </ul>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger w-100 fw-bold mb-2">
                            🗑️ Evet, Kalıcı Olarak Sil
                        </button>
                    </form>
                </div>

                <div class="card-footer text-center bg-white">
                    <a asp-action="Index" class="text-muted text-decoration-none">← İptal Et ve Listeye Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>