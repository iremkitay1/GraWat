@model IEnumerable<GraWat.Models.Urun>

@{
    ViewData["Title"] = "Ürün Yönetimi";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3 text-start">
        <h2 class="fw-bold fs-2 text-dark mb-0">
            <i class="bi bi-box-seam text-warning me-2"></i> Ürün ve Stok Yönetimi
        </h2>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm" style="border-radius: 30px;">
            ✨ Yeni Ürün Ekle
        </a>
    </div>

    <div class="card shadow border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-start ps-4">Ürün Adı</th>
                        <th>Kategori</th>
                        <th>Fiyat</th>
                        <th>Stok Durumu</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-start ps-4">@item.Ad</td>
                            <td><span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Kategori</span></td>
                            <td class="text-success fw-bold">@item.Fiyat.ToString("C")</td>
                            <td>
                                @if (item.StokAdedi > 20)
                                {
                                    <span class="badge bg-success px-3 py-2 rounded-pill">Yüksek (@item.StokAdedi)</span>
                                }
                                else if (item.StokAdedi > 0)
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Kritik (@item.StokAdedi)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2 rounded-pill">Tükendi (0)</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold">Stok/Düzenle</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger fw-bold">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>