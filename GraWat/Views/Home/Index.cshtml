@model IEnumerable<GraWat.Models.Urun>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>

    /* 1. Tüm sayfanın arkaplanı Gratis Moru */
        body {
                background-color: #5c1866;
                color: white;

    }


    /* 2. Mistral Fontu ve 3. Kaydırma Animasyonu */
        .grawat-baslik {
                font-family: 'Mistral', cursive, sans-serif;
                font-size: 6rem;
                color: white !important;
                animation: soldanGiris 1.2s ease-out; /* Animasyonu çağırıyoruz */

    }


    /* Animasyonun Matematiksel Çizimi (Ekran dışından gelip yerine oturur) */
        keyframes soldanGiris {
                0%

    {
                    transform: translateX(-100%);
                    opacity: 0;

    }

            100% {
                    transform: translateX(0);
                    opacity: 1;

    }


    }
</style>

<div class="text-center mt-5" style="padding-top: 50px;">
    <h1 class="grawat-baslik">GraWat'a Hoş Geldiniz!</h1>
    <p class="lead mt-4 text-light">Kozmetik ve güzelliğin yeni adresi. Ürünlerimizi keşfetmek veya aramıza katılmak için üst menüyü kullanabilirsiniz.</p>
    <hr class="w-50 mx-auto bg-light" style="height: 2px;" />
</div>

<div class="container mt-5">
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var urun in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-lg" style="border-radius: 15px; overflow: hidden; border: 2px solid #FFCC00;">
                        <div style="width: 100%; aspect-ratio: 1 / 1; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(urun.ResimYolu))
                            {
                                <img src="~/img/@urun.ResimYolu" class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;" alt="@urun.Ad">
                            }
                            else
                            {
                                <span class="fs-1" style="opacity: 0.3;">💄</span>
                            }
                        </div>

                        <div class="card-body text-center bg-white">
                            <h5 class="card-title fw-bold text-dark">@urun.Ad</h5>
                            <p class="card-text text-muted small">Kategori: @urun.Kategori</p>
                            <h5 class="text-success fw-bold">@urun.Fiyat ₺</h5>
                        </div>

                        <div class="card-footer bg-transparent border-0 bg-white pb-3">
                            @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin@gmail.com")
                            {
                                @* ADMİN İÇİN: urun.Id kullandık *@
                                <a asp-controller="Urunler" asp-action="Edit" asp-route-id="@urun.Id" class="btn btn-primary w-100 fw-bold shadow-sm py-2">
                                    <i class="bi bi-pencil-square me-2"></i> Stok Güncelle
                                </a>
                            }
                            else
                            {
                                @* MÜŞTERİ İÇİN: AJAX destekli buton *@
                                <button type="button"
                                        class="btn btn-warning w-100 fw-bold shadow-sm py-2 sepet-ekle-btn"
                                        data-id="@urun.Id">
                                    <i class="bi bi-cart-plus me-2"></i> Sepete Ekle
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-light mt-5 py-5">
                <i class="bi bi-emoji-frown fs-1" style="color: #FFCC00;"></i>

                <h3 class="mt-3 fw-bold">
                    @if (!string.IsNullOrEmpty(ViewBag.ArananKelime))
                    {
                        <span>Aradığın "@ViewBag.ArananKelime" vitrinimizde bulunamadı canım... ✨</span>
                    }
                    else
                    {
                        <span>Şu an vitrinimizde ürün bulunmamaktadır. Çok yakında buradayız! ✨</span>
                    }
                </h3>

                <p class="lead">Farklı bir anahtar kelime denemeye veya tüm ürünlerimize göz atmaya ne dersin?</p>

                <a href="/" class="btn btn-warning fw-bold px-4 py-2 mt-3 shadow-sm" style="border-radius: 25px; color: #3b0f42;">
                    <i class="bi bi-arrow-left-circle me-2"></i> Vitrine Geri Dön
                </a>
            </div>
        }
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".sepet-ekle-btn").click(function (e) {
                e.preventDefault(); // Sayfanın yukarı zıplamasını engeller

                var urunId = $(this).data("id");
                var buton = $(this);

                $.ajax({
                    url: '/Sepet/Ekle/' + urunId,
                    type: 'POST',
                    success: function () {
                        // 1. Üst menüdeki sepet sayısını güncelle (badge klasını bulur)
                        var badge = $(".badge");
                        var mevcutSayi = parseInt(badge.text()) || 0;
                        badge.text(mevcutSayi + 1);

                        // 2. Buton üzerinde anlık görsel geri bildirim
                        var eskiIcerik = buton.html();
                        buton.html('<i class="bi bi-check-lg"></i> Eklendi!');
                        buton.removeClass("btn-warning").addClass("btn-success");

                        // 2 saniye sonra butonu eski haline döndür
                        setTimeout(function () {
                            buton.html(eskiIcerik);
                            buton.removeClass("btn-success").addClass("btn-warning");
                        }, 2000);
                    },
                    error: function (xhr) {
                    // Eğer kullanıcı giriş yapmamışsa (Giriş yetkisi yoksa)
                    // Onu otomatik olarak giriş sayfasına uçuruyoruz
                    window.location.href = '/Identity/Account/Login';
                }
                });
            });
        });
    </script>
}