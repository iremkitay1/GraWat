@model IEnumerable<GraWat.Models.Siparis>

@{
    ViewData["Title"] = "Sipariş Geçmişim";
}

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 rounded-4 shadow-sm p-4 d-flex flex-row align-items-center welcome-card">
                <div class="icon-circle bg-warning text-dark me-4 shadow">
                    <i class="bi bi-bag-heart-fill fs-2"></i>
                </div>
                <div>
                    <h3 class="mb-1 fw-bold">Sipariş Geçmişim</h3>
                    <p class="mb-0 text-white-50">GraWat'tan verdiğiniz tüm siparişleri ve güncel durumlarını buradan takip edebilirsiniz.</p>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border shadow-sm">
            <div class="empty-cart-icon text-muted mb-3">
                <i class="bi bi-cart-x" style="font-size: 5rem;"></i>
            </div>
            <h4 class="fw-bold text-dark">Henüz bir siparişiniz bulunmuyor.</h4>
            <p class="text-muted">Güzelliğinize güzellik katacak ürünler sizi bekliyor!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-warning btn-lg mt-2 rounded-pill px-5 fw-bold shadow-sm">
                Alışverişe Başla <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 order-card">
                        <div class="card-header bg-light border-bottom-0 pt-4 pb-2 d-flex justify-content-between align-items-center rounded-top-4">
                            <span class="text-muted small fw-bold"><i class="bi bi-hash"></i> Sipariş No: @item.Id</span>

                            @if (item.Durum == "Hazırlanıyor")
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm">
                                    <i class="bi bi-box-seam me-1"></i> @item.Durum
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success px-3 py-2 rounded-pill shadow-sm">
                                    <i class="bi bi-check2-circle me-1"></i> @item.Durum
                                </span>
                            }
                        </div>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <div class="text-muted small"><i class="bi bi-calendar3 me-2"></i>Tarih</div>
                                <div class="fw-bold text-dark">@item.SiparisTarihi.ToString("dd MMMM yyyy")</div>
                            </div>

                            <div class="d-flex justify-content-between mb-3">
                                <div class="text-muted small"><i class="bi bi-credit-card me-2"></i>Ödeme Yöntemi</div>
                                <div class="fw-bold text-dark">@item.OdemeYontemi</div>
                            </div>

                            <hr class="text-muted opacity-25">

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="text-muted small text-uppercase fw-bold">Toplam Tutar</div>
                                <div class="fs-4 fw-bold text-success">@item.ToplamTutar.ToString("C2")</div>
                            </div>

                            <a asp-controller="Siparis"
                               asp-action="Degerlendir"
                               asp-route-urunId="@item.Id"
                               class="btn btn-outline-dark w-100 mt-3 rounded-pill fw-bold">
                                Ürünleri Değerlendir <i class="bi bi-star-fill text-warning ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .welcome-card {
        animation: fadeInDown 0.5s ease-out;
    }

    .order-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

        .order-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            border-color: #5c1866 !important; /* GraWat Moru ile şık bütünlük */
        }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>