@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="container mt-5 mb-5 pt-4">
    <style>
        .info-alert-banner {
            background: rgba(255, 255, 255, 0.12) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }
        .info-alert-banner:hover {
            background: rgba(255, 255, 255, 0.18) !important;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15) !important;
        }
        .info-alert-icon-wrapper {
            background: rgba(255, 204, 0, 0.15) !important;
            border: 1px solid rgba(255, 204, 0, 0.4) !important;
            color: #ffc107 !important;
            transition: transform 0.3s ease;
        }
        .info-alert-banner:hover .info-alert-icon-wrapper {
            transform: scale(1.1);
        }
    </style>

    <div class="row text-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-gear-wide-connected text-warning me-2"></i> Hesap Yönetim Paneli</h2>
        <div class="d-flex justify-content-center mt-2">
            <div class="info-alert-banner d-inline-flex align-items-center gap-3 px-4 py-3 rounded-4 shadow-sm border" style="max-width: 620px;">
                <div class="info-alert-icon-wrapper d-flex align-items-center justify-content-center rounded-circle" style="width: 42px; height: 42px; flex-shrink: 0;">
                    <i class="bi bi-shield-check fs-4"></i>
                </div>
                <p class="mb-0 text-start text-white fw-medium" style="font-size: 0.95rem; line-height: 1.5;">
                    GraWat hesabınızla ilgili tüm ayarları buradan güvenle yönetebilirsiniz.
                </p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sol Taraf: VIP Menü -->
        <div class="col-md-4 col-lg-3">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden sticky-top" style="top: 20px;">
                <div class="bg-dark p-4 text-center">
                    <div class="bg-warning text-dark rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-fill fs-1"></i>
                    </div>
                    <h6 class="text-white fw-bold mb-0 text-truncate">@User.Identity?.Name</h6>
                </div>
                <div class="p-2">
                    <partial name="_ManageNav" />
                </div>
            </div>
        </div>

        <!-- Sağ Taraf: Tıklanan Sayfanın İçeriği -->
        <div class="col-md-8 col-lg-9">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}