@model IEnumerable<GraWat.Models.Yorum>

@{
    ViewData["Title"] = "Ürün Değerlendirmeleri";
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <h2 class="fw-bold mb-4 text-danger"><i class="bi bi-chat-left-heart-fill"></i> Müşteri Değerlendirmeleri</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm" style="border-radius: 15px;">
            <i class="bi bi-info-circle-fill fs-4 d-block mb-2"></i>
            Şu an için mağazanızda yapılmış herhangi bir ürün değerlendirmesi bulunmuyor.
        </div>
    }
    else
    {
        <div class="card shadow border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Tarih</th>
                                <th>Müşteri</th>
                                <th>Puan</th>
                                <th>Yorum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var yorum in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@yorum.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="fw-bold">@yorum.KullaniciAdi</td>
                                    <td>
                                        @for (int i = 0; i < yorum.Puan; i++)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                    </td>
                                    <td style="max-width: 300px;" class="text-truncate" title="@yorum.YorumMetni">
                                        @yorum.YorumMetni
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="YorumSil" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@yorum.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold px-3 shadow-sm" onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?');">
                                                <i class="bi bi-trash3-fill"></i> Sil
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>