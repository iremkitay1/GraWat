@model IEnumerable<GraWat.Models.SepetItem>

@{
    ViewData["Title"] = "Sepetim";
}

<div class="container mt-5">
    <h2 class="mb-4" style="color: #5c1866 !important; font-weight: bold;">
        <i class="bi bi-cart-check-fill text-warning"></i> Alışveriş Sepetim
    </h2>

    <div class="card shadow-lg border-0" style="border-top: 4px solid #FFCC00; border-radius: 15px;">
        <div class="card-body py-4">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead style="background-color: #f8f9fa;">
                            <tr>
                                <th scope="col" class="text-secondary">Ürün Adı</th>
                                <th scope="col" class="text-secondary text-center">Kategori</th>
                                <th scope="col" class="text-secondary text-center">Adet</th>
                                <th scope="col" class="text-secondary text-end">Birim Fiyat</th>
                                <th scope="col" class="text-secondary text-end">Toplam</th>
                                <th scope="col" class="text-secondary text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@item.Urun.Ad</td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">@item.Urun.Kategori</span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center align-items-center">
                                            <a asp-action="Azalt" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary px-2 py-0 fw-bold shadow-sm">-</a>
                                            <span class="mx-3 fw-bold fs-5 text-dark">@item.Adet</span>
                                            <a asp-action="Artir" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary px-2 py-0 fw-bold shadow-sm">+</a>
                                        </div>
                                    </td>

                                    <td class="text-end text-success">@item.Urun.Fiyat ₺</td>
                                    <td class="text-end text-success fw-bold">@(item.Urun.Fiyat * item.Adet) ₺</td>

                                    <td class="text-center">
                                        <a asp-action="Sil" asp-route-id="@item.Id" class="btn btn-link text-danger p-0" title="Ürünü tamamen kaldır">
                                            <i class="bi bi-trash3-fill fs-4"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: #f8f9fa;">
                            <tr>
                                <td colspan="4" class="text-end fw-bold fs-5 text-dark" style="padding-top: 15px;">Genel Toplam:</td>
                                <td class="text-end fw-bold fs-4" style="color: #5c1866; padding-top: 15px;">
                                    @(Model.Sum(i => i.Urun.Fiyat * i.Adet)) ₺
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="text-end mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary fw-bold me-2">Alışverişe Devam Et</a>
                    <a asp-controller="Sepet" asp-action="Odeme" class="btn fw-bold shadow-sm py-2 px-4" style="background-color: #3b0f42; color: white; border-radius: 10px;">
                        Siparişi Tamamla 🚀
                    </a>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
                    <h4 class="text-muted mt-3">Sepetiniz şu an boş görünüyor.</h4>
                    <p class="text-secondary mb-4">Hemen ürünlerimize göz atıp sepetinizi doldurmaya başlayın!</p>
                    <a asp-controller="Home" asp-action="Index" class="btn fw-bold px-4 py-2" style="background-color: #5c1866; color: white; border-radius: 8px;">
                        Vitrine Geri Dön
                    </a>
                </div>
            }

        </div>
    </div>
</div>