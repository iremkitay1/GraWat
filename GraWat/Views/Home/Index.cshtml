@model IEnumerable<GraWat.Models.Urun>

@{
    ViewData["Title"] = "GraWat Vitrin";
}

<style>
    .filter-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    .filter-sidebar::-webkit-scrollbar-track {
        background: transparent;
    }
    .filter-sidebar::-webkit-scrollbar-thumb {
        background: rgba(59, 15, 66, 0.15);
        border-radius: 10px;
    }
    .filter-sidebar::-webkit-scrollbar-thumb:hover {
        background: rgba(59, 15, 66, 0.3);
    }

    /* Akordeon Filtre Tasarımı */
    .category-accordion-item {
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding-bottom: 8px;
    }
    .category-accordion-header {
        background-color: #f8f9fa;
        padding: 8px 12px;
        border-radius: 8px;
        transition: all 0.2s ease;
        user-select: none;
    }
    .category-accordion-header:hover {
        background-color: #f1f3f5;
    }
    .category-accordion-header:hover span {
        color: #3b0f42 !important;
    }
    .category-accordion-body {
        transition: all 0.3s ease-in-out;
    }
    .category-checkbox:checked + .form-check-label {
        color: #3b0f42 !important;
        font-weight: 600;
    }
</style>

<div class="container mt-5 mb-5">
    @* Premium Hero Section *@
    <div class="hero-section text-center mb-5 d-flex flex-column justify-content-center align-items-center position-relative overflow-hidden" 
         style="background-image: url('/img/hero_background.png'); background-size: cover; background-position: center; border-radius: 24px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35); min-height: 380px; padding: 5rem 2rem;">
        
        @* Dark Overlay for Readability *@
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(59, 15, 66, 0.65) 0%, rgba(20, 5, 25, 0.8) 100%); z-index: 1;"></div>
        
        @* Ambient Light Rings *@
        <div class="position-absolute" style="width: 250px; height: 250px; background: rgba(255, 204, 0, 0.15); border-radius: 50%; filter: blur(60px); top: -80px; left: -40px; pointer-events: none; z-index: 1;"></div>
        <div class="position-absolute" style="width: 300px; height: 300px; background: rgba(255, 255, 255, 0.1); border-radius: 50%; filter: blur(70px); bottom: -100px; right: -60px; pointer-events: none; z-index: 1;"></div>

        <div class="position-relative" style="z-index: 2; max-width: 800px;">
            <span class="badge bg-warning text-dark fw-bold mb-3 px-3 py-2 text-uppercase" style="letter-spacing: 2px; font-size: 0.8rem; border-radius: 8px; box-shadow: 0 4px 10px rgba(255, 204, 0, 0.35);">
                ✨ Kozmetik & Güzellik
            </span>
            <h1 class="display-2 fw-bold text-white mb-3" style="text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6); font-weight: 800; letter-spacing: -1px;">
                GraWat Dünyasına Hoş Geldiniz
            </h1>
            <p class="lead text-light opacity-90 mx-auto mb-0" style="line-height: 1.8; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5); font-weight: 400; font-size: 1.25rem; max-width: 680px;">
                Güzelliğinize zarafet ve ışıltı katacak, en özel formüllerle hazırlanmış seçkin ve kaliteli kozmetik koleksiyonunu keşfedin.
            </p>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Sol Taraf: Filtreleme Paneli -->
        <div class="col-lg-3 filter-sidebar" style="position: sticky; top: 80px; height: calc(100vh - 80px); overflow-y: auto;">
            <div class="card shadow-sm border-0 rounded-4 p-4 bg-white" 
                 style="border: 1px solid rgba(0,0,0,0.05) !important; border-right: 2px solid rgba(255, 204, 0, 0.35) !important; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06) !important;">
                <h5 class="fw-bold text-dark mb-4 d-flex align-items-center">
                    <i class="bi bi-funnel-fill text-warning me-2"></i> Filtrele & Ara
                </h5>
                
                <!-- Arama Kutusu -->
                <div class="mb-4 text-start">
                    <label class="form-label small fw-bold text-muted text-uppercase">Canlı Arama</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="liveSearchInput" class="form-control bg-light border-0" placeholder="Ürün adı ara..." value="@ViewBag.ArananKelime">
                    </div>
                </div>

                <!-- Kategoriler -->
                <div class="mb-4 text-start">
                    <label class="form-label small fw-bold text-muted text-uppercase mb-3">Kategoriler</label>
                    <div id="categoryFilterContainer">
                        
                        <!-- 1. Makyaj -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-palette text-primary me-2"></i> Makyaj
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Makyaj" id="catMakyaj">
                                    <label class="form-check-label small text-dark" for="catMakyaj">Tüm Makyaj</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Ruj" id="subRuj">
                                    <label class="form-check-label small text-muted" for="subRuj">Ruj</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Maskara" id="subMaskara">
                                    <label class="form-check-label small text-muted" for="subMaskara">Maskara</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Fondöten" id="subFondoten">
                                    <label class="form-check-label small text-muted" for="subFondoten">Fondöten</label>
                                </div>
                            </div>
                        </div>

                        <!-- 2. Cilt Bakım -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-droplet-half text-info me-2"></i> Cilt Bakım
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Cilt Bakım" id="catCilt">
                                    <label class="form-check-label small text-dark" for="catCilt">Tüm Cilt Bakımı</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Nemlendirici" id="subNemlendirici">
                                    <label class="form-check-label small text-muted" for="subNemlendirici">Nemlendirici</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Yüz Temizleme Jeli" id="subTemizleme">
                                    <label class="form-check-label small text-muted" for="subTemizleme">Yüz Temizleme Jeli</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Tonik" id="subTonik">
                                    <label class="form-check-label small text-muted" for="subTonik">Tonik</label>
                                </div>
                            </div>
                        </div>

                        <!-- 3. Güneş Ürünleri -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-sun text-warning me-2"></i> Güneş Ürünleri
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Güneş Ürünleri" id="catGunes">
                                    <label class="form-check-label small text-dark" for="catGunes">Tüm Güneş Ürünleri</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Yüz Güneş Kremi" id="subYuzGunes">
                                    <label class="form-check-label small text-muted" for="subYuzGunes">Yüz Güneş Kremi</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Vücut Güneş Kremi" id="subVucutGunes">
                                    <label class="form-check-label small text-muted" for="subVucutGunes">Vücut Güneş Kremi</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Bronzlaştırıcı Yağ" id="subBronzYag">
                                    <label class="form-check-label small text-muted" for="subBronzYag">Bronzlaştırıcı Yağ</label>
                                </div>
                            </div>
                        </div>

                        <!-- 4. Saç Bakım -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-scissors text-danger me-2"></i> Saç Bakım
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Saç Bakım" id="catSac">
                                    <label class="form-check-label small text-dark" for="catSac">Tüm Saç Bakımı</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Şampuan" id="subSampuan">
                                    <label class="form-check-label small text-muted" for="subSampuan">Şampuan</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Saç Kremi" id="subSacKremi">
                                    <label class="form-check-label small text-muted" for="subSacKremi">Saç Kremi</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Saç Maskesi" id="subSacMaskesi">
                                    <label class="form-check-label small text-muted" for="subSacMaskesi">Saç Maskesi</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Saç Boyası" id="subSacBoyasi">
                                    <label class="form-check-label small text-muted" for="subSacBoyasi">Saç Boyası</label>
                                </div>
                            </div>
                        </div>

                        <!-- 5. Parfüm & Deodorant -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-flower1 text-success me-2"></i> Parfüm & Deodorant
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Parfüm/Deodorant" id="catParfum">
                                    <label class="form-check-label small text-dark" for="catParfum">Tüm Parfüm & Deo</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Kadın Parfüm" id="subKadinParfum">
                                    <label class="form-check-label small text-muted" for="subKadinParfum">Kadın Parfüm</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Erkek Parfüm" id="subErkekParfum">
                                    <label class="form-check-label small text-muted" for="subErkekParfum">Erkek Parfüm</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Deodorant & Roll-on" id="subDeodorant">
                                    <label class="form-check-label small text-muted" for="subDeodorant">Deodorant & Roll-on</label>
                                </div>
                            </div>
                        </div>

                        <!-- 6. Erkek Bakım -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-person-fill-gear text-secondary me-2"></i> Erkek Bakım
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Erkek Bakım" id="catErkek">
                                    <label class="form-check-label small text-dark" for="catErkek">Tüm Erkek Bakımı</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Tıraş Ürünleri" id="subTiras">
                                    <label class="form-check-label small text-muted" for="subTiras">Tıraş Ürünleri</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Sakal & Bıyık Bakımı" id="subSakalBiyik">
                                    <label class="form-check-label small text-muted" for="subSakalBiyik">Sakal & Bıyık Bakımı</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Erkek Cilt Bakımı" id="subErkekCilt">
                                    <label class="form-check-label small text-muted" for="subErkekCilt">Erkek Cilt Bakımı</label>
                                </div>
                            </div>
                        </div>

                        <!-- 7. Kişisel Bakım -->
                        <div class="category-accordion-item mb-2">
                            <div class="category-accordion-header d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                <span class="fw-bold text-dark small d-flex align-items-center">
                                    <i class="bi bi-heart-pulse-fill text-warning me-2"></i> Kişisel Bakım
                                </span>
                                <i class="bi bi-plus-lg toggle-icon text-muted small"></i>
                            </div>
                            <div class="category-accordion-body ps-3 mt-2" style="display: none; opacity: 0;">
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Kişisel Bakım" id="catKisisel">
                                    <label class="form-check-label small text-dark" for="catKisisel">Tüm Kişisel Bakım</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Ağız & Diş Bakımı" id="subAgizDis">
                                    <label class="form-check-label small text-muted" for="subAgizDis">Ağız & Diş Bakımı</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Duş Jeli & Banyo" id="subDusJeli">
                                    <label class="form-check-label small text-muted" for="subDusJeli">Duş Jeli & Banyo</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input category-checkbox" type="checkbox" value="Kadın Hijyen Ürünleri" id="subKadinHijyen">
                                    <label class="form-check-label small text-muted" for="subKadinHijyen">Kadın Hijyen Ürünleri</label>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Fiyat Aralığı -->
                <div class="mb-4 text-start">
                    <label class="form-label small fw-bold text-muted text-uppercase">Fiyat Aralığı (TL)</label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="number" id="minPriceInput" class="form-control bg-light border-0 text-center px-1" placeholder="Min" min="0" style="font-size: 0.9rem;">
                        <span class="text-muted">-</span>
                        <input type="number" id="maxPriceInput" class="form-control bg-light border-0 text-center px-1" placeholder="Max" min="0" style="font-size: 0.9rem;">
                    </div>
                </div>

                <!-- Temizleme Butonu -->
                <button type="button" id="clearFiltersBtn" class="btn btn-outline-warning w-100 rounded-pill fw-bold btn-sm">
                    Filtreleri Temizle
                </button>
            </div>
        </div>

        <!-- Sağ Taraf: Ürün Vitrini -->
        <div class="col-lg-9 position-relative">
            <!-- Spinner / Yükleniyor Katmanı -->
            <div id="productLoadingOverlay" class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-none align-items-start justify-content-center pt-5" style="z-index: 10; border-radius: 20px;">
                <div class="d-flex flex-column align-items-center" style="margin-top: 100px;">
                    <div class="spinner-border text-warning" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <span class="mt-3 fw-bold text-dark">Ürünler yükleniyor...</span>
                </div>
            </div>

            <!-- Ürün Grid Container -->
            <div id="productsGridContainer" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <partial name="_ProductList" model="Model" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // URL Parametresinden Gelen Kategori ve Arama Kelimesini Seçili Yap ve Akordeonu Aç
            const urlParams = new URLSearchParams(window.location.search);
            const categoryParam = urlParams.get('kategori');
            const searchParam = urlParams.get('searchString');
            
            const openAndCheckAccordion = (value) => {
                document.querySelectorAll('.category-checkbox').forEach(cb => {
                    const val = cb.value.toLowerCase();
                    const targetVal = value.toLowerCase();
                    if (val === targetVal || (targetVal === 'cilt bakımı' && val === 'cilt bakım') || (targetVal === 'parfüm & deodorant' && val === 'parfüm/deodorant')) {
                        cb.checked = true;
                        
                        // İlgili akordeon gövdesini bul ve aç
                        const body = cb.closest('.category-accordion-body');
                        if (body) {
                            body.style.display = "block";
                            body.style.maxHeight = "500px";
                            body.style.opacity = "1";
                            
                            const header = body.previousElementSibling;
                            if (header) {
                                const icon = header.querySelector('.toggle-icon');
                                if (icon) {
                                    icon.classList.remove('bi-plus-lg');
                                    icon.classList.add('bi-dash-lg');
                                }
                                header.classList.add('bg-light');
                            }
                        }
                    }
                });
            };

            if (categoryParam) {
                openAndCheckAccordion(categoryParam);
            }
            if (searchParam) {
                openAndCheckAccordion(searchParam);
            }

            // Akordeon Aç/Kapat Mantığı
            document.querySelectorAll('.category-accordion-header').forEach(header => {
                header.addEventListener('click', function () {
                    const body = this.nextElementSibling;
                    const icon = this.querySelector('.toggle-icon');
                    
                    if (body.style.display === "none" || !body.style.display) {
                        body.style.display = "block";
                        body.style.maxHeight = "0px";
                        body.style.opacity = "0";
                        body.style.transition = "all 0.3s ease-in-out";
                        
                        setTimeout(() => {
                            body.style.maxHeight = "500px";
                            body.style.opacity = "1";
                        }, 10);
                        
                        icon.classList.remove('bi-plus-lg');
                        icon.classList.add('bi-dash-lg');
                        this.classList.add('bg-light');
                    } else {
                        body.style.maxHeight = "0px";
                        body.style.opacity = "0";
                        body.style.transition = "all 0.3s ease-in-out";
                        
                        setTimeout(() => {
                            body.style.display = "none";
                        }, 300);
                        
                        icon.classList.remove('bi-dash-lg');
                        icon.classList.add('bi-plus-lg');
                        this.classList.remove('bg-light');
                    }
                });
            });

            // AJAX Filtreleme İstek Fonksiyonu
            const applyFilters = () => {
                const search = document.getElementById('liveSearchInput').value;
                const minPrice = document.getElementById('minPriceInput').value;
                const maxPrice = document.getElementById('maxPriceInput').value;
                
                const categories = [];
                document.querySelectorAll('.category-checkbox:checked').forEach(cb => {
                    categories.push(cb.value);
                });
                
                // Query Parameter oluştur
                const params = new URLSearchParams();
                if (search) params.append('searchString', search);
                if (minPrice) params.append('minPrice', minPrice);
                if (maxPrice) params.append('maxPrice', maxPrice);
                categories.forEach(cat => params.append('kategoriler', cat));
                
                // URL'i sayfa yenilemeden güncelle
                const newUrl = window.location.pathname + '?' + params.toString();
                window.history.pushState({ path: newUrl }, '', newUrl);
                
                // Yükleme katmanını göster
                const overlay = document.getElementById('productLoadingOverlay');
                overlay.classList.remove('d-none');
                overlay.classList.add('d-flex');
                
                // AJAX Fetch İsteği Gönder
                fetch(newUrl, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(res => {
                    if (!res.ok) throw new Error("Arama yapılamadı.");
                    return res.text();
                })
                .then(html => {
                    document.getElementById('productsGridContainer').innerHTML = html;
                })
                .catch(err => console.error("Filter request error:", err))
                .finally(() => {
                    // Yükleme katmanını gizle
                    overlay.classList.remove('d-flex');
                    overlay.classList.add('d-none');
                });
            };

            // Debounce Optimizasyonu (Gecikmeli Arama)
            let debounceTimer;
            const debounce = (callback, delay = 300) => {
                return (...args) => {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(() => callback(...args), delay);
                };
            };

            // Olay Dinleyicileri (Event Listeners)
            document.getElementById('liveSearchInput').addEventListener('input', debounce(applyFilters, 300));
            document.getElementById('minPriceInput').addEventListener('input', debounce(applyFilters, 400));
            document.getElementById('maxPriceInput').addEventListener('input', debounce(applyFilters, 400));
            
            document.querySelectorAll('.category-checkbox').forEach(cb => {
                cb.addEventListener('change', applyFilters);
            });

            // Filtreleri Temizle Butonu
            document.getElementById('clearFiltersBtn').addEventListener('click', function () {
                document.getElementById('liveSearchInput').value = '';
                document.getElementById('minPriceInput').value = '';
                document.getElementById('maxPriceInput').value = '';
                document.querySelectorAll('.category-checkbox').forEach(cb => cb.checked = false);
                
                // Akordeonları kapat
                document.querySelectorAll('.category-accordion-body').forEach(body => {
                    body.style.display = "none";
                    body.style.maxHeight = "0px";
                    body.style.opacity = "0";
                    const header = body.previousElementSibling;
                    if (header) {
                        const icon = header.querySelector('.toggle-icon');
                        if (icon) {
                            icon.classList.remove('bi-dash-lg');
                            icon.classList.add('bi-plus-lg');
                        }
                        header.classList.remove('bg-light');
                    }
                });
                
                applyFilters();
            });
        });
    </script>
}