@model IEnumerable<GraWat.Models.Urun>

@{
    ViewData["Title"] = "GraWat Vitrin";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold" style="color: #5c1866;">✨ GraWat Dünyasına Hoş Geldiniz</h1>
        <p class="lead text-muted">Güzelliğinize güzellik katacak en özel ürünler burada...</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var urun in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 urun-karti d-flex flex-column justify-content-between">

                    <div>
                        <div class="position-relative w-100" style="padding-top: 100%; background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); border-radius: 15px 15px 0 0; overflow: hidden;">
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center p-3">
                                @if (!string.IsNullOrEmpty(urun.ResimYolu))
                                {
                                    <img src="/img/@urun.ResimYolu" style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 8px;" alt="@urun.Ad" />
                                }
                                else
                                {
                                    <span style="font-size: 4rem;">💄</span>
                                }
                            </div>
                        </div>

                        <div class="card-body text-center pt-3 pb-0">
                            <span class="badge bg-dark mb-2 px-3 py-1 rounded-pill">@urun.Kategori</span>
                            <h5 class="card-title fw-bold text-dark d-block text-truncate px-2" title="@urun.Ad" style="min-height: 24px;">
                                @urun.Ad
                            </h5>
                            <h4 class="text-success fw-bold mt-2">@urun.Fiyat.ToString("C")</h4>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 text-center pb-4 pt-2">
                        <div class="d-grid gap-2 px-2">
                            @if (urun.StokAdedi > 0)
                            {
                                <button type="button" class="btn btn-outline-dark rounded-pill fw-bold sepete-ekle-btn" data-id="@urun.Id" style="border-width: 2px;">
                                    <i class="bi bi-cart-plus"></i> Sepete Ekle
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary rounded-pill fw-bold" disabled>Maalesef Tükendi</button>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Kartların üzerine gelince hafif yukarı zıplama efekti */
    .urun-karti {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .urun-karti:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $(".sepete-ekle-btn").click(function (e) {
            e.preventDefault(); // Sayfanın yukarı kaymasını kesin olarak engeller

            var urunId = $(this).data("id");
            var buton = $(this);

            // Arka planda SepetController/Ekle action'ına sessizce istek atar
            $.post("/Sepet/Ekle/" + urunId, function () {

                // Kullanıcıya sepete eklendiğine dair anlık yeşil buton animasyonu
                var orijinalIcerik = buton.html();
                buton.removeClass("btn-outline-dark")
                     .addClass("btn-success text-white")
                     .html("<i class='bi bi-check-lg'></i> Eklendi");

                // 1 saniye sonra eski şık outline haline geri döndürür
                setTimeout(function () {
                    buton.removeClass("btn-success text-white")
                         .addClass("btn-outline-dark")
                         .html(orijinalIcerik);
                }, 1000);
            });
        });
    });
</script>