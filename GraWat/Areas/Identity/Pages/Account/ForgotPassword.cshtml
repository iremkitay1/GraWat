@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="container mt-5 pt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 auth-card">
                <div class="card-body p-5">
                    <!-- Üst Başlık ve İkon -->
                    <div class="text-center mb-4">
                        <div class="icon-circle bg-dark text-warning mx-auto mb-3 shadow">
                            <i class="bi bi-key-fill fs-1"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Şifremi Unuttum</h3>
                        <p class="text-muted small">Hesabınıza kayıtlı e-posta adresinizi girin. Size güvenli bir şifre sıfırlama bağlantısı göndereceğiz.</p>
                    </div>

                    <!-- Şifre Sıfırlama Formu -->
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-2"></i>E-posta Adresi</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-warning text-dark w-100 btn-lg rounded-3 fw-bold shadow mb-4">
                            Sıfırlama Bağlantısı Gönder <i class="bi bi-send ms-2"></i>
                        </button>
                    </form>

                    <!-- Alt Yönlendirme (Geri Dönüş) -->
                    <div class="text-center pt-3 border-top">
                        <p class="text-muted small mb-0">
                            Şifrenizi hatırladınız mı?
                            <a asp-page="./Login" class="text-dark fw-bold text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i> Giriş Yap
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>