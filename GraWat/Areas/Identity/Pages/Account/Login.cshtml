@page
@model LoginModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5 pt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 auth-card">
                <div class="card-body p-5">
                    <!-- Üst Başlık ve İkon -->
                    <div class="text-center mb-4">
                        <div class="icon-circle bg-dark text-warning mx-auto mb-3 shadow">
                            <i class="bi bi-person-circle fs-1"></i>
                        </div>
                        <h3 class="fw-bold text-dark">GraWat'a Giriş Yap</h3>
                        <p class="text-muted small">Favori ürünlerine ulaşmak için hemen giriş yap.</p>
                    </div>

                    <!-- Giriş Formu -->
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-2"></i>E-posta Adresi</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted"><i class="bi bi-lock me-2"></i>Şifre</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted small" asp-for="Input.RememberMe">Beni Hatırla</label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none text-warning fw-bold small">Şifremi Unuttum</a>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fw-bold shadow">
                            Giriş Yap <i class="bi bi-box-arrow-in-right ms-2"></i>
                        </button>
                    </form>

                    <!-- Alt Yönlendirme -->
                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted small mb-0">
                            Hesabın yok mu?
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-warning fw-bold text-decoration-none">Hemen Kayıt Ol</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>