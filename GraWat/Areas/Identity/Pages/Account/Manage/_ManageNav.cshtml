@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="card shadow-sm border-0 rounded-4 mb-4 mb-md-0 auth-card">
    <div class="card-body p-3">
        <h6 class="text-uppercase text-muted fw-bold mb-3 px-2 small">Hesap Ayarları</h6>
        <ul class="nav nav-pills flex-column nav-pills-custom gap-2">
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext) rounded-3 px-3 py-2" id="profile" asp-page="./Index">
                    <i class="bi bi-person-badge me-2"></i> Profilim
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext) rounded-3 px-3 py-2" id="email" asp-page="./Email">
                    <i class="bi bi-envelope-at me-2"></i> E-posta
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext) rounded-3 px-3 py-2" id="change-password" asp-page="./ChangePassword">
                    <i class="bi bi-shield-lock me-2"></i> Şifre Değiştir
                </a>
            </li>
            <!-- İhtiyaca göre diğer menüleri buraya ekleyebilirsiniz -->
        </ul>
    </div>
</div>

<style>
    /* Menü Butonları Tasarımı */
    .nav-pills-custom .nav-link {
        color: #6c757d;
        font-weight: 600;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }

        .nav-pills-custom .nav-link:hover {
            background-color: rgba(0,0,0,0.03);
            color: #212529;
        }

        /* Aktif (Seçili) Menü Tasarımı - GraWat Konsepti */
        .nav-pills-custom .nav-link.active {
            background-color: #212529 !important;
            color: #ffc107 !important;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border-color: #212529;
        }
</style>