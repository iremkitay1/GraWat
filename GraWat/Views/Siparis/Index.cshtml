@model GraWat.Models.Siparis

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="bi bi-receipt"></i> Sipariş Detayı #@Model.Id</h4>
            <a asp-action="TumSiparisler" class="btn btn-outline-light btn-sm">Listeye Dön</a>
        </div>
        <div class="card-body p-4 text-start">
            <div class="row">
                <!-- Müşteri ve Sipariş Bilgileri -->
                <div class="col-md-6 border-end">
                    <h5 class="text-primary mb-3 border-bottom pb-2">Müşteri Bilgileri</h5>
                    <p><strong>Müşteri ID:</strong> <span class="text-muted">@Model.KullaniciId</span></p>
                    <p><strong>Sipariş Tarihi:</strong> @Model.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</p>
                    <p>
                        <strong>Durum:</strong>
                        <span class="badge @(Model.Durum == "Hazırlanıyor" ? "bg-warning text-dark" : "bg-success")">
                            @Model.Durum
                        </span>
                    </p>
                </div>

                <!-- Ödeme Özeti -->
                <div class="col-md-6 ps-md-4">
                    <h5 class="text-primary mb-3 border-bottom pb-2">Ödeme Detayları</h5>
                    <div class="p-3 bg-light rounded-3 shadow-sm mb-3">
                        <p class="mb-2">
                            <strong>Ödeme Yöntemi:</strong>
                            <span class="badge bg-info text-dark">@Model.OdemeYontemi</span>
                        </p>
                        <h4 class="text-dark mb-0"><strong>Toplam Tutar:</strong> @Model.ToplamTutar.ToString("C2")</h4>
                    </div>
                    <div class="alert alert-secondary small">
                        <i class="bi bi-info-circle"></i> Bu sipariş, seçilen ödeme yöntemi ile onaylanmıştır.
                    </div>
                </div>
            </div>

            <!-- İşlem Butonları -->
            <div class="mt-4 pt-3 border-top text-center">
                <button class="btn btn-success me-2" onclick="window.print()">
                    <i class="bi bi-printer"></i> Siparişi Yazdır
                </button>
                <button class="btn btn-primary">
                    <i class="bi bi-truck"></i> Kargoya Ver
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        animation: fadeIn 0.5s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>