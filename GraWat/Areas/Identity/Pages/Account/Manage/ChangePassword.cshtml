@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="card shadow-lg border-0 rounded-4 auth-card">
    <div class="card-header bg-dark text-warning p-4 rounded-top-4 d-flex align-items-center">
        <i class="bi bi-key-fill fs-2 me-3"></i>
        <h4 class="mb-0 fw-bold text-white">Güvenlik ve Şifre</h4>
    </div>

    <div class="card-body p-4 p-md-5">
        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="row">
            <div class="col-lg-8">
                <p class="text-muted mb-4">Hesap güvenliğiniz için şifrenizi düzenli olarak değiştirmenizi tavsiye ederiz.</p>

                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="Mevcut Şifre" />
                        <label asp-for="Input.OldPassword" class="text-muted"><i class="bi bi-unlock me-2"></i>Mevcut Şifreniz</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.NewPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Yeni Şifre" />
                        <label asp-for="Input.NewPassword" class="text-muted"><i class="bi bi-lock me-2"></i>Yeni Şifre</label>
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Yeni Şifre Tekrar" />
                        <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="bi bi-check-all me-2"></i>Yeni Şifre (Tekrar)</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-warning btn-lg px-5 rounded-pill fw-bold shadow-sm w-100 w-md-auto">
                        Şifremi Güncelle <i class="bi bi-shield-check ms-2"></i>
                    </button>
                </form>
            </div>
            <!-- Sağ Taraf İllüstrasyon -->
            <div class="col-lg-4 d-none d-lg-flex align-items-center justify-content-center">
                <i class="bi bi-shield-lock text-light" style="font-size: 10rem; opacity: 0.5;"></i>
            </div>
        </div>
    </div>
</div>