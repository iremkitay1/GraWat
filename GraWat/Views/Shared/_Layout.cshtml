@using System.Security.Claims
@using GraWat.Data
@inject ApplicationDbContext _context
@inject GraWatContext _grawatContext

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GraWat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GraWat.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        /* SAYFA TEMELLERİ */
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
        }

        /* NAVBAR */
        .navbar {
            background-color: #3b0f42 !important;
            border-bottom: 2px solid #FFCC00 !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            width: 100% !important;
            z-index: 99999 !important;
            height: 70px !important;
        }

        .main-layout-wrapper {
            margin-top: 118px !important;
            background-color: #8c2c9c !important;
            color: white;
            min-height: calc(100vh - 118px);
            padding: 40px 0;
        }

        /* SUB-NAVBAR STİLLERİ */
        .sub-navbar {
            position: fixed !important;
            top: 70px !important;
            left: 0 !important;
            right: 0 !important;
            height: 48px !important;
            background-color: #4a1252 !important;
            z-index: 9999 !important;
            border-bottom: 2px solid #FFCC00 !important;
            white-space: nowrap !important;
            scrollbar-width: none !important; /* Firefox */
            -ms-overflow-style: none !important;  /* IE/Edge */
        }
        
        .sub-navbar::-webkit-scrollbar {
            display: none !important; /* Chrome/Safari */
        }

        /* Mobil ve küçük ekranlar için yatay kaydırma yapısını koru */
        @@media (max-width: 767.98px) {
            .sub-navbar {
                overflow-x: auto !important;
            }
            .subcategory-dropdown {
                display: none !important;
            }
        }

        /* Masaüstü ekranlarda menülerin taşmasını engellememek için overflow: visible yapıyoruz */
        @@media (min-width: 768px) {
            .sub-navbar {
                overflow: visible !important;
            }
        }

        .sub-nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            text-decoration: none !important;
            font-weight: bold !important;
            font-size: 0.9rem !important;
            padding: 8px 12px !important;
            transition: all 0.2s ease !important;
            display: inline-block !important;
        }

        .sub-nav-link:hover {
            color: #FFCC00 !important;
            text-shadow: 0px 0px 8px #FFCC00 !important;
        }

        .sub-nav-divider {
            width: 1px !important;
            height: 16px !important;
            background-color: rgba(255, 255, 255, 0.2) !important;
            margin: 0 4px !important;
            display: inline-block !important;
            vertical-align: middle !important;
            flex-shrink: 0 !important;
        }

        /* YENİ ALT KATEGORİ MENÜSÜ (DROPDOWN) STİLLERİ */
        .category-wrapper {
            position: relative !important;
            display: inline-block !important;
        }

        .subcategory-dropdown {
            position: absolute !important;
            top: 100% !important;
            left: 0 !important;
            background-color: #ffffff !important;
            box-shadow: 0px 8px 16px rgba(0,0,0,0.1) !important;
            z-index: 1050 !important;
            border-radius: 8px !important;
            padding: 12px 0 !important;
            min-width: 180px !important;
            opacity: 0 !important;
            visibility: hidden !important;
            transition: all 0.3s ease !important;
            text-align: left !important;
        }

        .category-wrapper:hover .subcategory-dropdown {
            opacity: 1 !important;
            visibility: visible !important;
        }

        .subcategory-dropdown a {
            display: block !important;
            padding: 8px 20px !important;
            color: #333333 !important;
            text-decoration: none !important;
            font-size: 0.85rem !important;
            font-weight: 500 !important;
            transition: all 0.2s ease !important;
        }

        .subcategory-dropdown a:hover {
            color: #3b0f42 !important; /* Projenin ana tema rengi (mor) */
            background-color: #f8f9fa !important;
        }

        .nav-link, .navbar-brand {
            color: #FFCC00 !important;
            font-weight: bold;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #FFF !important;
                text-shadow: 0px 0px 8px #FFCC00;
            }

        .side-link:hover {
            color: #FFCC00 !important;
            background-color: rgba(255, 255, 255, 0.1);
            padding-left: 25px !important;
            transition: 0.3s;
        }

        /* Form Kutuları Hover/Odaklanma Efektleri */
        .form-control:focus {
            border-color: #ffc107; /* Warning sarısı */
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
        }

        /* İkonları yuvarlak içine alan tasarım */
        .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Kartların açılış animasyonu */
        .auth-card {
            animation: fadeInDown 0.6s ease-out;
        }

        @@keyframes fadeInDown {
            from

        {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fs-3" data-bs-toggle="offcanvas" href="#kategoriMenu" style="font-family: 'Mistral', sans-serif;">
                    GraWat
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        @* SADECE ADMİN GİRİŞ YAPTIYSA BU BUTONU GÖSTER *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-area="" asp-controller="Urunler" asp-action="Index">
                                    👑 Ürün Yönetimi
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                                    🛍️ Ürünler
                                </a>
                            </li>
                        }

                        @* MÜŞTERİ İÇİN SİPARİŞLERİM *@
                        @if (User.Identity.IsAuthenticated && User.Identity.Name != "admin@gmail.com")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Siparis" asp-action="Siparislerim">Siparişlerim</a>
                            </li>
                        }

                        @* ADMIN İÇİN TÜM SİPARİŞLER *@
                        @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin@gmail.com")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold border border-danger rounded px-2 ms-2"
                                   asp-controller="Siparis" asp-action="TumSiparisler">
                                    <i class="bi bi-shield-lock-fill"></i> Sipariş Yönetimi
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @* SEPET VE FAVORİ SAYACI HESAPLAMA *@
                        @{
                            int sepetSayac = 0;
                            int favoriSayac = 0;
                            if (User.Identity.IsAuthenticated)
                            {
                                var aktifKullaniciId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                                sepetSayac = _context.SepetItems.Where(s => s.KullaniciId == aktifKullaniciId).Sum(s => s.Adet);
                                favoriSayac = _grawatContext.Favoriler.Count(f => f.KullaniciId == aktifKullaniciId);
                            }
                        }

                        @* FAVORİLERİM BUTONU (Sadece Müşteriye) *@
                        @if (User.Identity.IsAuthenticated && User.Identity.Name != "admin@gmail.com")
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link d-flex align-items-center" asp-controller="Profil" asp-action="Favorilerim">
                                    <i class="bi bi-heart fs-4 me-1 text-danger"></i>
                                    Favorilerim <span id="favori-badge" class="badge rounded-pill bg-danger ms-1">@favoriSayac</span>
                                </a>
                            </li>
                        }

                        @* SEPETİM BUTONU (Sadece Müşteriye) *@
                        @if (User.Identity.IsAuthenticated && User.Identity.Name != "admin@gmail.com")
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link d-flex align-items-center" asp-controller="Sepet" asp-action="Index">
                                    <i class="bi bi-cart3 fs-4 me-1"></i>
                                    Sepetim <span id="sepet-badge" class="badge rounded-pill bg-danger ms-1">@sepetSayac</span>
                                </a>
                            </li>
                        }

                        @* KULLANICI GİRİŞ/ÇIKIŞ VE FAVORİLER *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius: 10px;">
                                    <li>
                                        <a class="dropdown-item fw-bold text-warning" asp-controller="Profil" asp-action="Favorilerim">
                                            <i class="bi bi-star-fill"></i> Favorilerim
                                        </a>
                                    </li>
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-gear"></i> Hesap Ayarları</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                            <button type="submit" class="dropdown-item text-danger fw-bold"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-warning" asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus-fill"></i> Kayıt Ol
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        
        <!-- KATEGORİ SUB-NAVBAR -->
        <div class="sub-navbar">
            <div class="container d-flex align-items-center justify-content-start justify-content-md-center h-100">
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Makyaj" class="sub-nav-link">Makyaj</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Makyaj&searchString=Ruj">Ruj</a>
                        <a href="/Home/Index?kategori=Makyaj&searchString=Maskara">Maskara</a>
                        <a href="/Home/Index?kategori=Makyaj&searchString=Fondöten">Fondöten</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Cilt Bakım" class="sub-nav-link">Cilt Bakım</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Cilt Bakım&searchString=Nemlendirici">Nemlendirici</a>
                        <a href="/Home/Index?kategori=Cilt Bakım&searchString=Yüz Temizleme Jeli">Yüz Temizleme Jeli</a>
                        <a href="/Home/Index?kategori=Cilt Bakım&searchString=Tonik">Tonik</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Saç Bakım" class="sub-nav-link">Saç Bakım</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Saç Bakım&searchString=Şampuan">Şampuan</a>
                        <a href="/Home/Index?kategori=Saç Bakım&searchString=Saç Kremi">Saç Kremi</a>
                        <a href="/Home/Index?kategori=Saç Bakım&searchString=Saç Maskesi">Saç Maskesi</a>
                        <a href="/Home/Index?kategori=Saç Bakım&searchString=Saç Boyası">Saç Boyası</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Parfüm/Deodorant" class="sub-nav-link">Parfüm & Deodorant</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Parfüm/Deodorant&searchString=Kadın Parfüm">Kadın Parfüm</a>
                        <a href="/Home/Index?kategori=Parfüm/Deodorant&searchString=Erkek Parfüm">Erkek Parfüm</a>
                        <a href="/Home/Index?kategori=Parfüm/Deodorant&searchString=Deodorant & Roll-on">Deodorant & Roll-on</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Erkek Bakım" class="sub-nav-link">Erkek Bakım</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Erkek Bakım&searchString=Tıraş Ürünleri">Tıraş Ürünleri</a>
                        <a href="/Home/Index?kategori=Erkek Bakım&searchString=Sakal & Bıyık Bakımı">Sakal & Bıyık Bakımı</a>
                        <a href="/Home/Index?kategori=Erkek Bakım&searchString=Erkek Cilt Bakımı">Erkek Cilt Bakımı</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Kişisel Bakım" class="sub-nav-link">Kişisel Bakım</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Kişisel Bakım&searchString=Ağız & Diş Bakımı">Ağız & Diş Bakımı</a>
                        <a href="/Home/Index?kategori=Kişisel Bakım&searchString=Duş Jeli & Banyo">Duş Jeli & Banyo</a>
                        <a href="/Home/Index?kategori=Kişisel Bakım&searchString=Kadın Hijyen Ürünleri">Kadın Hijyen Ürünleri</a>
                    </div>
                </div>
                <span class="sub-nav-divider"></span>
                <div class="category-wrapper">
                    <a href="/Home/Index?kategori=Güneş Ürünleri" class="sub-nav-link">Güneş Ürünleri</a>
                    <div class="subcategory-dropdown">
                        <a href="/Home/Index?kategori=Güneş Ürünleri&searchString=Yüz Güneş Kremi">Yüz Güneş Kremi</a>
                        <a href="/Home/Index?kategori=Güneş Ürünleri&searchString=Vücut Güneş Kremi">Vücut Güneş Kremi</a>
                        <a href="/Home/Index?kategori=Güneş Ürünleri&searchString=Bronzlaştırıcı Yağ">Bronzlaştırıcı Yağ</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    @* SOL KATEGORİ MENÜSÜ *@
    <div class="offcanvas offcanvas-start" tabindex="-1" id="kategoriMenu" style="background-color: #3b0f42; color: white; width: 280px; border-right: 2px solid #FFCC00;">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title fw-bold" style="color: #FFCC00;">Kategoriler</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="list-group list-group-flush bg-transparent">
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index" class="text-white text-decoration-none side-link d-block p-3">Tümü</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Makyaj" class="text-white text-decoration-none side-link d-block p-3">Makyaj</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Cilt Bakım" class="text-white text-decoration-none side-link d-block p-3">Cilt Bakımı</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Güneş Ürünleri" class="text-white text-decoration-none side-link d-block p-3">Güneş Ürünleri</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Saç Bakım" class="text-white text-decoration-none side-link d-block p-3">Saç Bakımı</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Parfüm/Deodorant" class="text-white text-decoration-none side-link d-block p-3">Parfüm / Deodorant</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Erkek Bakım" class="text-white text-decoration-none side-link d-block p-3">Erkek Bakımı</a></li>
                <li class="list-group-item bg-transparent border-0"><a href="/Home/Index?kategori=Kişisel Bakım" class="text-white text-decoration-none side-link d-block p-3">Kişisel Bakım</a></li>
            </ul>
        </div>
    </div>

    <div class="main-layout-wrapper">
        <div class="container text-center">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
        <footer class="footer text-center text-light mt-5 border-top border-warning pt-3">
            <div class="container"> &copy; 2026 - GraWat Kozmetik 💄 </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- AKILLI GÜZELLİK ASİSTANI CHAT ARAYÜZÜ -->
    <div class="chat-widget-container">
        <!-- Sohbet Açma Butonu -->
        <button class="chat-toggle-btn" id="chatToggleBtn" title="Güzellik Asistanı">
            <i class="bi bi-chat-dots-fill"></i>
        </button>

        <!-- Sohbet Kutusu -->
        <div class="chat-box" id="chatBox">
            <!-- Başlık -->
            <div class="chat-header">
                <span class="chat-header-title">
                    <i class="bi bi-stars"></i> Güzellik Asistanı
                </span>
                <button class="chat-header-close" id="chatCloseBtn">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Mesajlar -->
            <div class="chat-messages" id="chatMessages">
                <div class="chat-message assistant">
                    Merhaba! Ben GraWat Güzellik Asistanı. Size nasıl yardımcı olabilirim? 🌸
                </div>
            </div>

            <!-- Giriş Alanı -->
            <div class="chat-input-container">
                <input type="text" class="chat-input" id="chatInput" placeholder="Mesajınızı yazın..." autocomplete="off" />
                <button class="chat-send-btn" id="chatSendBtn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Sohbet Kontrol JavaScript -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const chatToggleBtn = document.getElementById("chatToggleBtn");
            const chatCloseBtn = document.getElementById("chatCloseBtn");
            const chatBox = document.getElementById("chatBox");
            const chatInput = document.getElementById("chatInput");
            const chatSendBtn = document.getElementById("chatSendBtn");
            const chatMessages = document.getElementById("chatMessages");

            // Sohbet pencerisini aç/kapat
            chatToggleBtn.addEventListener("click", () => {
                chatBox.classList.toggle("active");
                if (chatBox.classList.contains("active")) {
                    chatInput.focus();
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            });

            chatCloseBtn.addEventListener("click", () => {
                chatBox.classList.remove("active");
            });

            // Enter tuşuyla gönderme
            chatInput.addEventListener("keypress", (e) => {
                if (e.key === "Enter") {
                    sendMessage();
                }
            });

            chatSendBtn.addEventListener("click", sendMessage);

            async function sendMessage() {
                const messageText = chatInput.value.trim();
                if (!messageText) return;

                // Girişi temizle
                chatInput.value = "";

                // Kullanıcı mesajını ekle
                appendMessage(messageText, "user");

                // 'Düşünüyor' göstergesini ekle
                const typingIndicator = appendTypingIndicator();

                try {
                    // Fetch API ile istek gönder
                    const response = await fetch('/Chat/SendMessage', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ message: messageText })
                    });

                    // Düşünüyor göstergesini kaldır
                    typingIndicator.remove();

                    if (response.ok) {
                        const data = await response.json();
                        if (data.success) {
                            appendMessage(data.reply, "assistant");
                        } else {
                            appendMessage("Bir hata oluştu: " + (data.reply || "Bilinmeyen hata"), "assistant");
                        }
                    } else {
                        appendMessage("Sunucuyla bağlantı kurulamadı. Lütfen tekrar deneyin.", "assistant");
                    }
                } catch (error) {
                    typingIndicator.remove();
                    appendMessage("Bir ağ hatası oluştu. Lütfen bağlantınızı kontrol edin.", "assistant");
                    console.error("Chat error:", error);
                }
            }

            function appendMessage(text, sender) {
                const messageDiv = document.createElement("div");
                messageDiv.classList.add("chat-message", sender);
                
                // Satır sonlarını br etiketlerine çevir
                messageDiv.innerHTML = text.replace(/\n/g, "<br>");
                
                chatMessages.appendChild(messageDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            function appendTypingIndicator() {
                const typingDiv = document.createElement("div");
                typingDiv.classList.add("chat-message", "assistant", "typing");
                typingDiv.innerHTML = '✨ Düşünüyor <div class="typing-dots"><span></span><span></span><span></span></div>';
                chatMessages.appendChild(typingDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                return typingDiv;
            }
        });
    </script>
</body>
</html>