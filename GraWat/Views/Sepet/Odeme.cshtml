@model GraWat.Models.Siparis

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">💳 Ödeme Seçenekleri</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SiparisOnayla" method="post" id="odemeForm">

                        <div class="payment-options">
                            <!-- 1. Kredi Kartı Seçeneği -->
                            <div class="form-check payment-card mb-3 p-3 border rounded-3 shadow-sm" onclick="selectPaymentMethod('kart')">
                                <input class="form-check-input" type="radio" name="odemeYontemi" id="kart" value="Kredi Kartı" checked>
                                <label class="form-check-label d-flex align-items-center w-100" for="kart">
                                    <i class="bi bi-credit-card-2-front fs-3 me-3 text-primary"></i>
                                    <div>
                                        <span class="fw-bold d-block">Online Kredi / Banka Kartı</span>
                                        <small class="text-muted">Güvenli ödeme altyapısı ile şimdi ödeyin.</small>
                                    </div>
                                </label>
                            </div>

                            <!-- AKILLI KART FORMU -->
                            <div id="cardDetailsForm" class="p-4 border rounded-3 mb-4 bg-light shadow-inner">
                                <h6 class="mb-3 text-primary"><i class="bi bi-shield-lock-fill"></i> Kart Bilgileri</h6>

                                <div class="mb-3 text-start">
                                    <label class="form-label small fw-bold text-dark">Kart Üzerindeki İsim</label>
                                    <input type="text" name="kartIsim" id="kartIsim" class="form-control" placeholder="Ad Soyad" maxlength="50" required>
                                </div>

                                <div class="mb-3 text-start">
                                    <label class="form-label small fw-bold text-dark">Kart Numarası</label>
                                    <input type="text" id="cardNo" name="cardNo" class="form-control"
                                           placeholder="0000 0000 0000 0000"
                                           maxlength="19"
                                           oninput="formatCardNumber(this)" required>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3 text-start">
                                        <label class="form-label small fw-bold text-dark">Son Kullanma (AA/YY)</label>
                                        <input type="text" id="expiryDate" name="expiryDate" class="form-control"
                                               placeholder="MM/YY"
                                               maxlength="5"
                                               oninput="formatExpiry(this)" required>
                                    </div>
                                    <div class="col-md-6 mb-3 text-start">
                                        <label class="form-label small fw-bold text-dark">CVV</label>
                                        <input type="text" name="cvv" id="cvv" class="form-control"
                                               placeholder="123"
                                               maxlength="3"
                                               oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                    </div>
                                </div>
                                <div class="text-muted small text-start">
                                    <i class="bi bi-lock-fill"></i> 256-bit SSL şifreleme ile korunmaktadır.
                                </div>
                            </div>

                            <!-- 2. Kapıda Nakit -->
                            <div class="form-check payment-card mb-3 p-3 border rounded-3 shadow-sm" onclick="selectPaymentMethod('nakit')">
                                <input class="form-check-input" type="radio" name="odemeYontemi" id="nakit" value="Kapıda Nakit">
                                <label class="form-check-label d-flex align-items-center w-100" for="nakit">
                                    <i class="bi bi-cash-stack fs-3 me-3 text-success"></i>
                                    <div>
                                        <span class="fw-bold d-block">Kapıda Nakit Ödeme</span>
                                        <small class="text-muted">Ürününüz kapıya geldiğinde nakit olarak ödeyin.</small>
                                    </div>
                                </label>
                            </div>

                            <!-- 3. Kapıda Kart -->
                            <div class="form-check payment-card mb-4 p-3 border rounded-3 shadow-sm" onclick="selectPaymentMethod('kapidaKart')">
                                <input class="form-check-input" type="radio" name="odemeYontemi" id="kapidaKart" value="Kapıda Kart">
                                <label class="form-check-label d-flex align-items-center w-100" for="kapidaKart">
                                    <i class="bi bi-person-vcard fs-3 me-3 text-info"></i>
                                    <div>
                                        <span class="fw-bold d-block">Kapıda Kredi Kartı</span>
                                        <small class="text-muted">Kuryedeki POS cihazı ile kapıda kartla ödeyin.</small>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold shadow">
                                Siparişi Onayla <i class="bi bi-check-circle-fill ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Formu açıp kapatan ve validation niteliklerini düzenleyen fonksiyon
    function toggleCardForm(show) {
        const form = document.getElementById('cardDetailsForm');
        if (form) {
            form.style.display = show ? 'block' : 'none';
            const inputs = form.querySelectorAll('input');
            inputs.forEach(input => {
                if (show) {
                    input.setAttribute('required', 'required');
                    input.removeAttribute('disabled');
                } else {
                    input.removeAttribute('required');
                    input.setAttribute('disabled', 'disabled');
                }
            });
        }
    }

    // Seçilen ödeme yöntemini check edip formu toggle eden fonksiyon
    function selectPaymentMethod(radioId) {
        const radio = document.getElementById(radioId);
        if (radio) {
            radio.checked = true;
            toggleCardForm(radioId === 'kart');
        }
    }

    // Kart numarasını 4'lü gruplar halinde ayırır
    function formatCardNumber(input) {
        let value = input.value.replace(/\s+/g, '').replace(/[^0-9]/g, '');
        let formattedValue = value.match(/.{1,4}/g)?.join(' ') || value;
        input.value = formattedValue;
    }

    // Tarihe otomatik "/" ekler
    function formatExpiry(input) {
        let value = input.value.replace(/[^0-9]/g, '');
        if (value.length > 2) {
            input.value = value.substring(0, 2) + '/' + value.substring(2, 4);
        } else {
            input.value = value;
        }
    }

    // Sayfa yüklendiğinde varsayılan seçeneğe göre formun ayarlanması
    document.addEventListener("DOMContentLoaded", function () {
        const kartRadio = document.getElementById('kart');
        if (kartRadio) {
            toggleCardForm(kartRadio.checked);
        }
    });

    // AJAX ile Sipariş Formu Yönetimi
    document.getElementById('odemeForm').addEventListener('submit', function (e) {
        e.preventDefault();

        const form = e.target;
        const formData = new FormData(form);

        // Şık Yükleme Göstergesi (SweetAlert2)
        Swal.fire({
            title: 'Siparişiniz İşleniyor...',
            text: 'Lütfen bekleyiniz.',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Şık Başarı Animasyonu
                Swal.fire({
                    title: 'Siparişiniz Başarıyla Alındı!',
                    text: 'Sipariş onay sayfasına yönlendiriliyorsunuz...',
                    icon: 'success',
                    timer: 2500,
                    showConfirmButton: false,
                    timerProgressBar: true,
                    allowOutsideClick: false
                }).then(() => {
                    // Zamanlamalı Yönlendirme (Redirect)
                    window.location.href = '/Sepet/SiparisBasarili';
                });
            } else {
                Swal.fire({
                    title: 'Hata!',
                    text: data.message || 'Sipariş onaylanırken bir hata oluştu.',
                    icon: 'error',
                    confirmButtonText: 'Tamam'
                });
            }
        })
        .catch(error => {
            console.error('Error:', error);
            Swal.fire({
                title: 'Hata!',
                text: 'Sunucu ile bağlantı kurulamadı. Lütfen tekrar deneyin.',
                icon: 'error',
                confirmButtonText: 'Tamam'
            });
        });
    });
</script>

<style>
    .payment-card {
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .payment-card:hover {
            transform: translateY(-2px);
            border-color: #3b0f42 !important;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
        }

    #cardDetailsForm {
        display: block;
        animation: slideDown 0.4s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-control:focus {
        border-color: #3b0f42;
        box-shadow: 0 0 0 0.25rem rgba(59, 15, 66, 0.25);
    }
</style>